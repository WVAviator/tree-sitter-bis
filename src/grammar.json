        "type": "SEQ",
        "members": [
          {
            "type": "PATTERN",
            "value": "[^\\n]*"
          },
          {
            "type": "PATTERN",
            "value": "\\n"
          }
        ]
      }
    },
    "variable": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "PATTERN",
          "value": "[^>]+"
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "variable_type": {
      "type": "SEQ",
      "members": [
        {
          "type": "PATTERN",
          "value": "[afhiosAFHIOS]"
        },
        {
          "type": "PATTERN",
          "value": "\\d{1,3}"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "\\.\\d{1,2}"
