        {
          "type": "SYMBOL",
          "name": "stmt_prefix"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "PATTERN",
            "value": "\\s"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_stmt_contents"
          }
